.ho-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.ho-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 12% 0%, rgba(16, 185, 129, 0.18) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 20%, rgba(37, 99, 235, 0.12) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.ho-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 48rpx;
}

.ho-hero {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.ho-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.ho-code {
  display: block;
  margin-top: 12rpx;
  font-size: 64rpx;
  font-weight: 900;
  letter-spacing: 12rpx;
  color: #0f766e;
}

.ho-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 22rpx;
  color: #94a3b8;
  line-height: 1.4;
}

.ho-card {
  margin-top: 24rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 22rpx 20rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.ho-card-title {
  display: block;
  font-size: 26rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 16rpx;
}

.ho-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.ho-row:last-child {
  margin-bottom: 0;
}

.ho-row-label {
  width: 200rpx;
  flex-shrink: 0;
  font-size: 22rpx;
  color: #475569;
}

.ho-row-bar {
  flex: 1;
  height: 14rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.ho-row-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #10b981 0%, #2563eb 100%);
}

.ho-row-num {
  width: 48rpx;
  text-align: right;
  font-size: 22rpx;
  font-weight: 800;
  color: #334155;
}

.ho-tips {
  font-size: 26rpx;
  color: #475569;
  line-height: 1.55;
}

.ho-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ho-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 0;
  line-height: 1.2;
  text-align: center;
}

.ho-btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

.ho-btn-primary {
  background: linear-gradient(90deg, #10b981 0%, #0d9488 48%, #2563eb 100%);
}

.ho-btn-primary .ho-btn-text {
  color: #ffffff;
}

.ho-btn-ghost {
  background: #ffffff;
  border: 1rpx solid #bbf7d0;
}

.ho-btn-ghost .ho-btn-text {
  color: #0f766e;
}
