<view class="ho-page">
  <view class="ho-bg"></view>
  <view class="ho-inner">
    <view class="ho-hero">
      <text class="ho-label">霍兰德兴趣码（前三位）</text>
      <text class="ho-code">{{code}}</text>
      <text class="ho-sub">得分越高排序越靠前 · 简版自测仅供参考</text>
    </view>

    <view class="ho-card">
      <text class="ho-card-title">六维得分</text>
      <view class="ho-row" wx:for="{{scoreRows}}" wx:for-item="row" wx:key="key">
        <text class="ho-row-label">{{row.label}}</text>
        <view class="ho-row-bar">
          <view class="ho-row-fill" style="width: {{row.pct}}%;"></view>
        </view>
        <text class="ho-row-num">{{row.count}}</text>
      </view>
    </view>

    <view class="ho-card" wx:if="{{topTips}}">
      <text class="ho-card-title">与你最贴近的三类兴趣</text>
      <text class="ho-tips">{{topTips}}</text>
    </view>

    <view class="ho-actions">
      <button class="result-share-native" open-type="share">分享给好友</button>
      <button class="result-share-native" bindtap="shareTimelineTip">分享到朋友圈</button>
      <view class="ho-btn ho-btn-primary" bindtap="goRetest">
        <text class="ho-btn-text">再测一次</text>
      </view>
      <view class="ho-btn ho-btn-ghost" bindtap="goHome">
        <text class="ho-btn-text">返回首页</text>
      </view>
    </view>
  </view>
</view>
