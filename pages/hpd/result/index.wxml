<view class="hpdr-page">
  <view class="hpdr-bg"></view>
  <view class="hpdr-inner">
    <view class="hpdr-hero">
      <text class="hpdr-label">表演型人格倾向 · 15题筛查</text>
      <text class="hpdr-tier">{{tierLabel}}</text>
      <text class="hpdr-score">{{totalScore}} / {{maxScore}} 分</text>
      <text class="hpdr-note">自测筛查 · 不构成医学诊断</text>
    </view>
    <view class="hpdr-card">
      <text class="hpdr-desc">{{tierDesc}}</text>
    </view>
    <view class="hpdr-actions">
      <button class="result-share-native" open-type="share">分享给好友</button>
      <button class="result-share-native" bindtap="shareTimelineTip">分享到朋友圈</button>
      <view class="hpdr-btn hpdr-btn-primary" bindtap="goRetest">
        <text class="hpdr-btn-text">再测一次</text>
      </view>
      <view class="hpdr-btn hpdr-btn-ghost" bindtap="goHome">
        <text class="hpdr-btn-text">返回首页</text>
      </view>
    </view>
  </view>
</view>
