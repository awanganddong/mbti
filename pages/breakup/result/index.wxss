.result-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 15% 0%, rgba(71, 85, 105, 0.30) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(900rpx 900rpx at 85% 10%, rgba(148, 163, 184, 0.16) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 20rpx 70rpx rgba(0, 0, 0, 0.40);
  backdrop-filter: blur(10px);
}

.hero-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.95);
}

.hero-badge {
  font-size: 22rpx;
  color: rgba(203, 213, 225, 0.98);
  background: rgba(71, 85, 105, 0.22);
  border: 1rpx solid rgba(148, 163, 184, 0.35);
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.hero-subtitle {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 14rpx;
  display: block;
}

.hero-hint {
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 12rpx;
  display: block;
}

.hero-hint-sub {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.45);
}

.hero-desc {
  margin-top: 10rpx;
}

.paragraph {
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.86);
  margin-top: 16rpx;
  display: block;
}

.disclaimer-card {
  margin-top: 22rpx;
  background: rgba(71, 85, 105, 0.18);
  border: 1rpx solid rgba(148, 163, 184, 0.28);
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
}

.disclaimer-title {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(226, 232, 240, 0.95);
  display: block;
  margin-bottom: 12rpx;
}

.disclaimer-body {
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.78);
  display: block;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.action-primary {
  background: linear-gradient(90deg, #64748b 0%, #475569 55%, #94a3b8 120%);
  color: #ffffff;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

