.page-root {
  min-height: 100vh;
}

.result-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 15% 0%, rgba(236, 72, 153, 0.22) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(900rpx 900rpx at 85% 10%, rgba(99, 102, 241, 0.22) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 20rpx 70rpx rgba(0, 0, 0, 0.40);
  backdrop-filter: blur(10px);
}

.hero-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.95);
}

.hero-badge {
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(251, 191, 36, 0.98);
  background: rgba(251, 191, 36, 0.14);
  border: 1rpx solid rgba(251, 191, 36, 0.28);
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
}

.hero-subtitle {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.78);
  margin-top: 14rpx;
  display: block;
}

.hero-hint {
  font-size: 22rpx;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.55);
  margin-top: 12rpx;
  display: block;
}

.score-list {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.score-row-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.88);
  flex: 1;
  padding-right: 16rpx;
}

.score-num {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(96, 165, 250, 0.95);
}

.score-track {
  height: 14rpx;
  background: rgba(255, 255, 255, 0.10);
  border-radius: 999rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  background: linear-gradient(90deg, #6366f1 0%, #22c55e 50%, #ec4899 100%);
  border-radius: 999rpx;
}

.score-fill-dim {
  background: linear-gradient(90deg, #fbbf24 0%, #ec4899 100%);
}

.hero-card-flat {
  margin-top: 22rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.90);
  display: block;
  margin-bottom: 16rpx;
}

.dim-row {
  margin-bottom: 22rpx;
}

.dim-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.dim-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
}

.dim-sim {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(251, 191, 36, 0.95);
}

.dim-pair {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.dim-mini {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.62);
}

.dim-mini-ta {
  color: rgba(167, 139, 250, 0.95);
}

.narrative {
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.86);
  display: block;
}

.disclaimer-card {
  margin-top: 22rpx;
  background: rgba(251, 191, 36, 0.10);
  border: 1rpx solid rgba(251, 191, 36, 0.35);
  border-radius: 22rpx;
  padding: 22rpx 24rpx;
}

.disclaimer-title {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(255, 237, 180, 0.95);
  display: block;
  margin-bottom: 12rpx;
}

.disclaimer-body {
  font-size: 24rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.78);
  display: block;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.action-primary {
  background: linear-gradient(90deg, #ec4899 0%, #6366f1 60%, #22c55e 120%);
  color: #ffffff;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}
