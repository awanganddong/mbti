.page {
  padding: 24rpx;
}

.empty {
  display: block;
  text-align: center;
  color: #999;
  margin-top: 80rpx;
}

.row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  border: 1px solid #eee;
}

.row-main {
  flex: 1;
  min-width: 0;
}

.type {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
  color: #4298ff;
}

.sub {
  display: block;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.time {
  font-size: 22rpx;
  color: #aaa;
  flex-shrink: 0;
  margin-left: 16rpx;
}
