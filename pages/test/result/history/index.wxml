<view class="hist-page">
  <view class="hist-bg"></view>
  <view class="hist-inner">
    <view class="hist-empty" wx:if="{{!list.length}}">
      <text class="hist-empty-text">暂无记录，去完成一次 MBTI 吧</text>
    </view>
    <view class="hist-list" wx:else>
      <view
        class="hist-item"
        wx:for="{{list}}"
        wx:key="timestamp"
        hover-class="hist-item-hover"
        data-type="{{item.type}}"
        data-id="{{item.timestamp}}"
        bindtap="openResult"
      >
        <view class="hist-main">
          <text class="hist-title">{{item.title || 'MBTI'}}</text>
          <text class="hist-sub">{{item.type}} · {{item.timeText}}</text>
        </view>
        <text class="hist-arrow">›</text>
      </view>
    </view>
  </view>
</view>
