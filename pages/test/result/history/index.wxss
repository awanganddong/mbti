.page-title {
  font-size: 36rpx;
  font-weight: bold;
  margin: 30rpx 0;
  text-align: center;
}

.empty-history {
  text-align: center;
  padding: 100rpx 0;
}

.empty-history text {
  font-size: 28rpx;
  color: #999;
  display: block;
  margin-bottom: 30rpx;
}

.history-list {
  margin-top: 20rpx;
}

.history-item {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.history-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
  display: block;
}

.history-result {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  display: block;
}

.history-item .btn {
  margin: 0;
}