.hist-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.hist-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 10% 0%, rgba(192, 132, 252, 0.16) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.hist-inner {
  position: relative;
  z-index: 1;
  padding: 24rpx 28rpx 48rpx;
}

.hist-empty {
  padding: 120rpx 24rpx;
  text-align: center;
}

.hist-empty-text {
  font-size: 28rpx;
  color: #64748b;
}

.hist-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.hist-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 22rpx;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  box-shadow: 0 8rpx 28rpx rgba(15, 23, 42, 0.05);
}

.hist-item-hover {
  opacity: 0.96;
}

.hist-main {
  flex: 1;
  min-width: 0;
}

.hist-title {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
}

.hist-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.hist-arrow {
  font-size: 36rpx;
  color: #cbd5e1;
  padding-left: 12rpx;
}
