<view class="res-page">
  <view class="res-bg"></view>
  <view class="res-inner">
    <view class="res-hero">
      <text class="res-label">你的 MBTI 类型</text>
      <text class="res-type">{{type}}</text>
      <text class="res-epithet" wx:if="{{epithet}}">{{epithet}}</text>
    </view>
    <view class="res-card" wx:if="{{description}}">
      <text class="res-desc">{{description}}</text>
    </view>
    <view class="res-actions">
      <button class="result-share-native" open-type="share">分享给好友</button>
      <button class="result-share-native" bindtap="shareTimelineTip">分享到朋友圈</button>
      <view class="res-btn res-btn-primary" bindtap="goRetest">
        <text class="res-btn-text">再测一次</text>
      </view>
      <view class="res-btn res-btn-ghost" bindtap="goHome">
        <text class="res-btn-text">返回首页</text>
      </view>
      <view class="res-btn res-btn-ghost" bindtap="goHistory">
        <text class="res-btn-text">测试记录</text>
      </view>
    </view>
  </view>
</view>
