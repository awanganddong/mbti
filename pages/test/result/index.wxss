.result-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 15% 0%, rgba(99, 102, 241, 0.30) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(900rpx 900rpx at 85% 10%, rgba(16, 185, 129, 0.18) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 20rpx 70rpx rgba(0, 0, 0, 0.40);
  backdrop-filter: blur(10px);
}

.hero-header {
  margin-bottom: 18rpx;
}

.hero-title-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-wrap: wrap;
}

.hero-type {
  font-size: 56rpx;
  font-weight: 800;
  letter-spacing: 2rpx;
  color: rgba(255, 255, 255, 0.95);
}

.hero-badge {
  font-size: 22rpx;
  color: rgba(34, 197, 94, 0.95);
  background: rgba(34, 197, 94, 0.14);
  border: 1rpx solid rgba(34, 197, 94, 0.22);
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.hero-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
  margin-top: 8rpx;
  display: block;
}

.hero-image {
  width: 240rpx;
  height: 240rpx;
  margin: 10rpx auto 6rpx;
  display: block;
}

.hero-desc {
  margin-top: 10rpx;
}

.paragraph {
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 16rpx;
  display: block;
}

.notice {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  border-radius: 18rpx;
  background: rgba(245, 158, 11, 0.10);
  border: 1rpx solid rgba(245, 158, 11, 0.22);
}

.notice-text {
  font-size: 24rpx;
  color: rgba(245, 158, 11, 0.92);
  line-height: 1.6;
  display: block;
}

.section-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 22rpx;
  padding: 24rpx;
  margin-top: 18rpx;
  backdrop-filter: blur(10px);
}

.section-header {
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
}

.score-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.score-row:last-child {
  border-bottom: none;
}

.score-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.72);
}

.score-value {
  font-size: 28rpx;
  font-weight: 700;
  color: rgba(96, 165, 250, 0.95);
}

.kv-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 18rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.kv-row:last-child {
  border-bottom: none;
}

.kv-label {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.64);
  flex-shrink: 0;
}

.kv-value {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.88);
  text-align: right;
  flex: 1;
}

.list-item {
  display: flex;
  gap: 12rpx;
  padding: 12rpx 0;
}

.list-dot {
  font-size: 26rpx;
  color: rgba(99, 102, 241, 0.95);
  width: 44rpx;
  flex-shrink: 0;
}

.list-text {
  font-size: 28rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.88);
  flex: 1;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.action-primary {
  background: linear-gradient(90deg, #6366f1 0%, #3b82f6 60%, #22c55e 120%);
  color: #ffffff;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

