.res-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.res-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 12% 0%, rgba(192, 132, 252, 0.2) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 20%, rgba(99, 102, 241, 0.14) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.res-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 48rpx;
}

.res-hero {
  text-align: center;
  padding: 24rpx 0 8rpx;
}

.res-label {
  display: block;
  font-size: 24rpx;
  color: #64748b;
  font-weight: 600;
}

.res-type {
  display: block;
  margin-top: 12rpx;
  font-size: 72rpx;
  font-weight: 900;
  letter-spacing: 4rpx;
  color: #5b21b6;
}

.res-epithet {
  display: block;
  margin-top: 12rpx;
  font-size: 32rpx;
  font-weight: 800;
  color: #334155;
}

.res-card {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.res-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.55;
}

.res-actions {
  margin-top: 36rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.res-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 0;
  line-height: 1.2;
  text-align: center;
}

.res-btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

.res-btn-primary {
  background: linear-gradient(90deg, #a855f7 0%, #6366f1 100%);
  color: #ffffff;
  border: none;
}

.res-btn-primary .res-btn-text {
  color: #ffffff;
}

.res-btn-ghost {
  background: #ffffff;
  color: #5b21b6;
  border: 1rpx solid #e9d5ff;
}

.res-btn-ghost .res-btn-text {
  color: #5b21b6;
}
