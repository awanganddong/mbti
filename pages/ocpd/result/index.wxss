.ocpdr-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.ocpdr-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 10% 0%, rgba(56, 189, 248, 0.16) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 18%, rgba(71, 85, 105, 0.12) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.ocpdr-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 48rpx;
}

.ocpdr-hero {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.ocpdr-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1.35;
}

.ocpdr-tier {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #0c4a6e;
}

.ocpdr-score {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #475569;
}

.ocpdr-note {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.ocpdr-card {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.ocpdr-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.55;
}

.ocpdr-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ocpdr-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 0;
  line-height: 1.2;
  text-align: center;
}

.ocpdr-btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

.ocpdr-btn-primary {
  background: linear-gradient(90deg, #0ea5e9 0%, #64748b 100%);
}

.ocpdr-btn-primary .ocpdr-btn-text {
  color: #ffffff;
}

.ocpdr-btn-ghost {
  background: #ffffff;
  border: 1rpx solid #bae6fd;
}

.ocpdr-btn-ghost .ocpdr-btn-text {
  color: #0369a1;
}
