.page {
  padding: 32rpx;
  padding-bottom: 48rpx;
}

.progress-wrap {
  margin-bottom: 24rpx;
}

.progress-text {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: #888;
  margin-top: 8rpx;
}

.q-num {
  text-align: center;
  font-weight: bold;
  margin-bottom: 16rpx;
}

.question {
  display: block;
  font-size: 32rpx;
  line-height: 1.55;
  margin-bottom: 32rpx;
}

.opts {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.opt {
  display: flex;
  align-items: flex-start;
  padding: 24rpx;
  background: #fff;
  border-radius: 12rpx;
  border: 1px solid #e0e0e0;
}

.opt-label {
  font-weight: bold;
  color: #4298ff;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.opt-text {
  flex: 1;
  line-height: 1.5;
}

.btn-prev {
  margin-top: 40rpx;
  background: #f0f0f0;
  color: #333;
}
