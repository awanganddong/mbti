.hidden-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
  color: #2b2448;
  background: #fff4fb;
}

.soft-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 520rpx at 8% 5%, rgba(216, 180, 254, 0.42), rgba(255, 244, 251, 0) 64%),
    radial-gradient(780rpx 520rpx at 96% 0%, rgba(251, 207, 232, 0.56), rgba(255, 244, 251, 0) 58%),
    linear-gradient(160deg, #fbf7ff 0%, #fff2f9 48%, #f7f2ff 100%);
  pointer-events: none;
}

.home-screen,
.input-screen,
.result-screen,
.detail-screen {
  position: relative;
  z-index: 1;
  min-height: 100vh;
  padding: 36rpx 32rpx calc(42rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.home-top,
.nav-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.menu-icon {
  width: 52rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.menu-icon view {
  width: 36rpx;
  height: 4rpx;
  border-radius: 99rpx;
  background: #2b2448;
}

.coin-pill,
.done-pill,
.share-btn {
  display: flex;
  align-items: center;
  gap: 10rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  padding: 12rpx 18rpx;
  box-shadow: 0 12rpx 34rpx rgba(190, 128, 214, 0.16);
  font-size: 24rpx;
  color: #5b5278;
}

.plus {
  color: #ff78b2;
  font-weight: 900;
}

.hero-copy {
  margin-top: 112rpx;
}

.brand {
  display: block;
  font-size: 64rpx;
  line-height: 1.05;
  font-weight: 900;
  color: #28223f;
}

.brand-ai {
  color: #ff69aa;
}

.subtitle,
.input-sub,
.result-summary,
.paragraph {
  display: block;
  margin-top: 20rpx;
  font-size: 26rpx;
  line-height: 1.75;
  color: #6d6687;
}

.photo-stack {
  margin: 92rpx auto 70rpx;
  width: 350rpx;
  height: 420rpx;
  position: relative;
  transform: rotate(2deg);
}

.main-photo {
  width: 100%;
  height: 100%;
  border-radius: 18rpx;
  border: 14rpx solid #ffffff;
  box-shadow: 0 20rpx 52rpx rgba(118, 81, 146, 0.22);
}

.bubble {
  position: absolute;
  z-index: 2;
  padding: 18rpx 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 16rpx 34rpx rgba(179, 128, 188, 0.18);
  font-size: 24rpx;
  color: #4a416b;
}

.b1 { left: -100rpx; top: 34rpx; }
.b2 { right: -112rpx; top: 160rpx; }
.b3 { left: -88rpx; bottom: 44rpx; }

.primary-btn,
.ghost-btn {
  width: 520rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 999rpx;
  padding: 0;
  font-size: 28rpx;
  font-weight: 800;
}

.primary-btn {
  color: #ffffff;
  background: linear-gradient(90deg, #c084fc 0%, #fb6fae 100%);
  box-shadow: 0 18rpx 44rpx rgba(244, 114, 182, 0.28);
}

.ghost-btn {
  margin-top: 22rpx;
  color: #b682df;
  background: rgba(255, 255, 255, 0.54);
  border: 2rpx solid rgba(216, 180, 254, 0.55);
}

button::after {
  border: none;
}

.back {
  width: 56rpx;
  height: 56rpx;
  line-height: 50rpx;
  font-size: 58rpx;
  color: #241d3f;
}

.page-title {
  font-size: 32rpx;
  font-weight: 900;
  color: #241d3f;
}

.share-btn {
  height: 56rpx;
  line-height: 56rpx;
  margin: 0;
  padding: 0 22rpx;
  background: #ff9ac4;
  color: #ffffff;
  font-size: 22rpx;
}

.input-head {
  margin-top: 58rpx;
  text-align: center;
}

.input-title {
  display: block;
  font-size: 38rpx;
  font-weight: 900;
}

.preview-card,
.analysis-card,
.tabs-card,
.note-card {
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.78);
  box-shadow: 0 18rpx 48rpx rgba(175, 126, 198, 0.12);
}

.preview-card {
  margin-top: 44rpx;
  padding: 18rpx;
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.preview-img {
  width: 128rpx;
  height: 128rpx;
  border-radius: 24rpx;
}

.preview-text {
  font-size: 26rpx;
  color: #7b7197;
}

.desc-box {
  margin-top: 28rpx;
  width: 100%;
  height: 360rpx;
  box-sizing: border-box;
  padding: 30rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.82);
  color: #3a3158;
  font-size: 27rpx;
  line-height: 1.7;
  box-shadow: 0 18rpx 48rpx rgba(175, 126, 198, 0.12);
}

.counter {
  display: block;
  margin-top: -54rpx;
  padding-right: 28rpx;
  text-align: right;
  color: #aaa1bf;
  font-size: 22rpx;
}

.prompt-title {
  margin-top: 54rpx;
  font-size: 24rpx;
  color: #8a7a9f;
}

.prompt-list {
  margin-top: 18rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.prompt {
  padding: 16rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #7a668e;
  font-size: 24rpx;
}

.bottom-btn {
  margin-top: 120rpx;
}

.avatar-orbit {
  margin: 62rpx auto 24rpx;
  width: 310rpx;
  height: 310rpx;
  border-radius: 999rpx;
  padding: 24rpx;
  background: conic-gradient(from 40deg, #f9a8d4, #ddd6fe, #ffffff, #f9a8d4);
  box-shadow: 0 24rpx 70rpx rgba(192, 132, 252, 0.18);
}

.avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
}

.done-pill {
  width: 188rpx;
  margin: 0 auto 32rpx;
  color: #b37be2;
  background: rgba(232, 213, 255, 0.82);
  justify-content: center;
}

.impression {
  display: block;
  text-align: center;
  font-size: 28rpx;
  color: #3a3158;
}

.result-title {
  display: block;
  margin-top: 18rpx;
  text-align: center;
  font-size: 50rpx;
  line-height: 1.25;
  font-weight: 900;
  color: #b77aef;
}

.result-summary {
  text-align: center;
  padding: 0 22rpx;
}

.stat-row {
  margin-top: 42rpx;
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.stat-card {
  min-height: 178rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.84);
  box-shadow: 0 16rpx 40rpx rgba(178, 129, 199, 0.12);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.stat-icon { font-size: 42rpx; }
.stat-label { font-size: 22rpx; color: #a57bc4; }
.stat-value { font-size: 30rpx; font-weight: 900; color: #322953; }

.note-card {
  margin: 30rpx 0;
  padding: 26rpx 30rpx;
  font-size: 25rpx;
  line-height: 1.65;
  color: #6f6487;
}

.tabs-card {
  margin-top: 36rpx;
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  padding: 12rpx;
  gap: 8rpx;
}

.detail-tab {
  height: 58rpx;
  line-height: 58rpx;
  text-align: center;
  border-radius: 999rpx;
  color: #7d7195;
  font-size: 22rpx;
}

.detail-tab-on {
  background: #fff0f7;
  color: #ff69a6;
  font-weight: 900;
}

.analysis-card {
  margin-top: 28rpx;
  padding: 34rpx;
  position: relative;
  overflow: hidden;
}

.card-title {
  display: block;
  font-size: 30rpx;
  font-weight: 900;
  color: #2d254a;
  margin-bottom: 24rpx;
}

.keyword-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 18rpx;
}

.keyword {
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 16rpx;
  background: #f7eaff;
  color: #9b6fd4;
  font-size: 24rpx;
  text-align: center;
}

.planet {
  position: absolute;
  right: 22rpx;
  bottom: 20rpx;
  font-size: 72rpx;
  opacity: 0.72;
}

.axis {
  display: grid;
  grid-template-columns: 126rpx 1fr 126rpx;
  align-items: center;
  gap: 14rpx;
  margin-top: 28rpx;
}

.axis-name {
  font-size: 23rpx;
  color: #625978;
}

.axis-name.right {
  text-align: right;
}

.axis-track {
  position: relative;
  height: 10rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #e9d5ff 0%, #fbcfe8 100%);
}

.axis-dot {
  position: absolute;
  top: 50%;
  width: 28rpx;
  height: 28rpx;
  margin-left: -14rpx;
  margin-top: -14rpx;
  border-radius: 999rpx;
  background: #c084fc;
  box-shadow: 0 0 0 8rpx rgba(192, 132, 252, 0.14);
}

.spacer {
  width: 56rpx;
}
