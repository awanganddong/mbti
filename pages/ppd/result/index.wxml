<view class="ppdr-page">
  <view class="ppdr-bg"></view>
  <view class="ppdr-inner">
    <view class="ppdr-hero">
      <text class="ppdr-label">偏执型人格倾向 · 15题筛查</text>
      <text class="ppdr-tier">{{tierLabel}}</text>
      <text class="ppdr-score">{{totalScore}} / {{maxScore}} 分</text>
      <text class="ppdr-note">自测筛查 · 不构成医学诊断</text>
    </view>
    <view class="ppdr-card">
      <text class="ppdr-desc">{{tierDesc}}</text>
    </view>
    <view class="ppdr-actions">
      <button class="result-share-native" open-type="share">分享给好友</button>
      <button class="result-share-native" bindtap="shareTimelineTip">分享到朋友圈</button>
      <view class="ppdr-btn ppdr-btn-primary" bindtap="goRetest">
        <text class="ppdr-btn-text">再测一次</text>
      </view>
      <view class="ppdr-btn ppdr-btn-ghost" bindtap="goHome">
        <text class="ppdr-btn-text">返回首页</text>
      </view>
    </view>
  </view>
</view>
