.ppdr-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.ppdr-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 10% 0%, rgba(245, 158, 11, 0.16) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 18%, rgba(120, 113, 108, 0.12) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.ppdr-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 48rpx;
}

.ppdr-hero {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.ppdr-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1.35;
}

.ppdr-tier {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #78350f;
}

.ppdr-score {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #475569;
}

.ppdr-note {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.ppdr-card {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.ppdr-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.55;
}

.ppdr-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.ppdr-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 0;
  line-height: 1.2;
  text-align: center;
}

.ppdr-btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

.ppdr-btn-primary {
  background: linear-gradient(90deg, #f59e0e 0%, #78716c 100%);
}

.ppdr-btn-primary .ppdr-btn-text {
  color: #ffffff;
}

.ppdr-btn-ghost {
  background: #ffffff;
  border: 1rpx solid #fde68a;
}

.ppdr-btn-ghost .ppdr-btn-text {
  color: #92400e;
}
