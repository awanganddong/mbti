<view class="result-page">
  <view class="container">
    <view class="hero-card">
      <view class="hero-header">
        <view class="hero-title-row">
          <text class="hero-title">荣格八维</text>
          <text class="hero-badge">{{topTwoLabel}}</text>
        </view>
        <text class="hero-subtitle" wx:if="{{typeGuess}}">参考类型：{{typeGuess}}（仅供参考）</text>
        <text class="hero-hint">得分越高表示该认知功能倾向越强；同分按 Ne→Ni→Se→Si→Te→Ti→Fe→Fi 顺序。</text>
      </view>

      <view class="score-list">
        <view class="score-row" wx:for="{{sortedScores}}" wx:key="key">
          <view class="score-row-head">
            <text class="score-label">{{item.label}}</text>
            <text class="score-num">{{item.score}}</text>
          </view>
          <view class="score-track">
            <view class="score-fill" style="width: {{item.barPercent}}%"></view>
          </view>
        </view>
      </view>
    </view>

    <view class="hero-card hero-card-flat">
      <text class="section-title">{{resultTitle}}</text>
      <view class="hero-desc">
        <text class="paragraph" wx:for="{{resultDescriptionParagraphs}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="actions">
      <button class="action-btn action-secondary" open-type="share">分享好友</button>
      <button class="action-btn action-secondary" bindtap="shareTimelineTip">分享朋友圈</button>
    </view>

    <view class="actions">
      <button class="action-btn action-secondary" bindtap="takeTestAgain">再测一次</button>
      <button class="action-btn action-primary" bindtap="goHome">返回首页</button>
    </view>
  </view>
</view>
