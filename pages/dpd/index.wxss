@import "../bpd/index.wxss";

.dpd-page .test-bg.dpd-bg {
  background:
    radial-gradient(720rpx 320rpx at 8% 0%, rgba(56, 189, 248, 0.18) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 16%, rgba(100, 116, 139, 0.12) 0%, rgba(255, 255, 255, 0) 55%);
}

.dpd-page .dpd-bar-fill {
  background: linear-gradient(90deg, #38bdf8 0%, #64748b 100%);
}

.dpd-page .test-opt-type {
  color: #0369a1;
}

.dpd-page .test-opt-hover {
  border-color: #bae6fd;
  background: #f0f9ff;
}
