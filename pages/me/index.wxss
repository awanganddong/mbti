.me-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 18% 12%, rgba(34, 211, 238, 0.12) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(900rpx 900rpx at 82% 0%, rgba(168, 85, 247, 0.16) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.section {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
  backdrop-filter: blur(8px);
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
}

.section-actions {
  display: flex;
  gap: 12rpx;
  flex-shrink: 0;
}

.mini-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  font-size: 24rpx;
  font-weight: 600;
}

.mini-btn-danger {
  background: rgba(239, 68, 68, 0.14);
  border-color: rgba(239, 68, 68, 0.30);
}

.profile {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.avatar {
  width: 104rpx;
  height: 104rpx;
  border-radius: 999rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.18);
  background: rgba(255, 255, 255, 0.10);
  flex-shrink: 0;
}

.avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.06);
}

.avatar-placeholder-text {
  font-size: 44rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.70);
  line-height: 1;
}

.profile-main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.profile-name {
  font-size: 34rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.96);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
}

.profile-actions {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  flex-shrink: 0;
}

.profile-actions .mini-btn {
  height: 56rpx;
  line-height: 56rpx;
  font-size: 22rpx;
  padding: 0 16rpx;
}

.empty {
  padding: 16rpx 0 4rpx;
}

.empty-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.60);
}
