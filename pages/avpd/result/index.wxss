.avpdr-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.avpdr-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 10% 0%, rgba(148, 163, 184, 0.22) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 18%, rgba(99, 102, 241, 0.12) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.avpdr-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 48rpx;
}

.avpdr-hero {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.avpdr-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1.35;
}

.avpdr-tier {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #334155;
}

.avpdr-score {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #475569;
}

.avpdr-note {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.avpdr-card {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.avpdr-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.55;
}

.avpdr-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.avpdr-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 0;
  line-height: 1.2;
  text-align: center;
}

.avpdr-btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

.avpdr-btn-primary {
  background: linear-gradient(90deg, #64748b 0%, #6366f1 48%, #4338ca 100%);
}

.avpdr-btn-primary .avpdr-btn-text {
  color: #ffffff;
}

.avpdr-btn-ghost {
  background: #ffffff;
  border: 1rpx solid #cbd5e1;
}

.avpdr-btn-ghost .avpdr-btn-text {
  color: #475569;
}
