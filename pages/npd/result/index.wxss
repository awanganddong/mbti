.npdr-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.npdr-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 10% 0%, rgba(234, 179, 8, 0.16) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 18%, rgba(124, 58, 237, 0.1) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.npdr-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 48rpx;
}

.npdr-hero {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.npdr-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1.35;
}

.npdr-tier {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #713f12;
}

.npdr-score {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #475569;
}

.npdr-note {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.npdr-card {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.npdr-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.55;
}

.npdr-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.npdr-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 0;
  line-height: 1.2;
  text-align: center;
}

.npdr-btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

.npdr-btn-primary {
  background: linear-gradient(90deg, #eab308 0%, #7c3aed 100%);
}

.npdr-btn-primary .npdr-btn-text {
  color: #ffffff;
}

.npdr-btn-ghost {
  background: #ffffff;
  border: 1rpx solid #fde047;
}

.npdr-btn-ghost .npdr-btn-text {
  color: #a16207;
}
