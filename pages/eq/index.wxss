.test-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.test-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 10% 0%, rgba(192, 132, 252, 0.18) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 18%, rgba(99, 102, 241, 0.12) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.test-inner {
  position: relative;
  z-index: 1;
  padding: 24rpx 28rpx 48rpx;
}

.test-loading {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.test-loading-text {
  font-size: 28rpx;
  color: #64748b;
}

.test-head {
  margin-bottom: 20rpx;
}

.test-progress {
  font-size: 24rpx;
  font-weight: 700;
  color: #64748b;
}

.test-bar {
  margin-top: 12rpx;
  height: 10rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
  overflow: hidden;
}

.test-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #a855f7 0%, #6366f1 100%);
  transition: width 0.2s ease;
}

.test-card {
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 28rpx 24rpx 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.test-q {
  display: block;
  font-size: 30rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.45;
}

.test-opts {
  margin-top: 28rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.test-opt {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  padding: 22rpx 20rpx;
  border-radius: 18rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
}

.test-opt-hover {
  opacity: 0.92;
  border-color: #fcd34d;
  background: #fffbeb;
}

.test-opt-type {
  flex-shrink: 0;
  width: 40rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 800;
  color: #7c3aed;
}

.test-opt-answer {
  flex: 1;
  font-size: 28rpx;
  color: #334155;
  line-height: 1.45;
}

.eq-page .test-bg.eq-bg {
  background:
    radial-gradient(720rpx 320rpx at 8% 0%, rgba(251, 191, 36, 0.22) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 16%, rgba(244, 114, 182, 0.16) 0%, rgba(255, 255, 255, 0) 55%);
}

.eq-page .eq-bar-fill {
  background: linear-gradient(90deg, #f59e0b 0%, #ec4899 48%, #a855f7 100%);
}

.eq-page .test-opt-type {
  color: #b45309;
}
