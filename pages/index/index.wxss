.explore-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
  color: #111827;
}

.explore-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(1000rpx 520rpx at 20% -10%, rgba(167, 139, 250, 0.22) 0%, rgba(244, 246, 251, 0) 55%),
    radial-gradient(900rpx 480rpx at 95% 0%, rgba(96, 165, 250, 0.18) 0%, rgba(244, 246, 251, 0) 50%),
    radial-gradient(800rpx 600rpx at 50% 100%, rgba(244, 114, 182, 0.12) 0%, rgba(244, 246, 251, 0) 55%);
  pointer-events: none;
}

.container {
  position: relative;
  z-index: 1;
  padding: 8rpx 28rpx 0;
  box-sizing: border-box;
}

.topbar {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding-top: 8rpx;
}

.topbar-left {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  min-width: 0;
  flex-shrink: 0;
}

.topbar-brand-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.topbar-sparkle {
  width: 40rpx;
  height: 40rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #e879f9 0%, #a855f7 45%, #6366f1 100%);
  box-shadow: 0 6rpx 20rpx rgba(124, 58, 237, 0.25);
}

.topbar-sparkle-core {
  font-size: 22rpx;
  color: #ffffff;
  line-height: 1;
}

.topbar-title {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.1;
}

.topbar-sub {
  font-size: 20rpx;
  color: #64748b;
  padding-left: 50rpx;
}

.tabs-row {
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.tabs {
  flex: 1;
  min-width: 0;
  white-space: nowrap;
}

.tabs-inner {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 6rpx 0 12rpx;
}

.tab {
  position: relative;
  padding: 12rpx 18rpx 14rpx;
  flex-shrink: 0;
}

.tab-text {
  font-size: 26rpx;
  color: #64748b;
}

.tab-active .tab-text {
  color: #5b21b6;
  font-weight: 800;
}

.tab-underline {
  position: absolute;
  left: 50%;
  transform: translateX(-50%);
  bottom: 4rpx;
  width: 48rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #a855f7 0%, #6366f1 100%);
  box-shadow: 0 0 12rpx rgba(124, 58, 237, 0.35);
}

.hero {
  margin-top: 22rpx;
  border-radius: 28rpx;
  border: 1rpx solid #ede9fe;
  background: linear-gradient(165deg, #faf5ff 0%, #eef2ff 45%, #ffffff 100%);
  box-shadow: 0 16rpx 48rpx rgba(91, 33, 182, 0.08);
  padding: 24rpx 22rpx 22rpx;
  position: relative;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 8% 0%, rgba(192, 132, 252, 0.35) 0%, rgba(255, 255, 255, 0) 58%),
    radial-gradient(640rpx 300rpx at 100% 20%, rgba(99, 102, 241, 0.22) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
}

.hero-stars {
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
}

.hero-star {
  position: absolute;
  width: 6rpx;
  height: 6rpx;
  border-radius: 999rpx;
  background: rgba(124, 58, 237, 0.35);
}

.hero-star.s1 { top: 18%; left: 12%; opacity: 0.9; }
.hero-star.s2 { top: 28%; right: 18%; opacity: 0.65; width: 4rpx; height: 4rpx; }
.hero-star.s3 { bottom: 22%; left: 22%; opacity: 0.5; width: 5rpx; height: 5rpx; }

.hero-badge {
  position: relative;
  z-index: 1;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid #e9d5ff;
}

.hero-badge-emoji {
  font-size: 22rpx;
  line-height: 1;
}

.hero-badge-text {
  font-size: 22rpx;
  color: #4c1d95;
  font-weight: 700;
}

.hero-main {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 18rpx;
  margin-top: 18rpx;
}

.hero-left {
  flex: 1;
  min-width: 0;
}

.hero-title {
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.15;
  color: #111827;
  display: block;
}

.hero-title-accent {
  color: #6366f1;
  text-shadow: none;
}

.hero-subtitle {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #64748b;
}

.hero-foot {
  margin-top: 18rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.hero-people {
  font-size: 22rpx;
  color: #64748b;
}

.hero-people-chev {
  font-size: 26rpx;
  color: #94a3b8;
  font-weight: 300;
}

.avatar-group {
  display: flex;
}

.avatar-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 999rpx;
  border: 2rpx solid #ffffff;
  margin-left: -10rpx;
}

.avatar-dot.ad1 { background: linear-gradient(135deg, #60a5fa 0%, #a78bfa 100%); margin-left: 0; }
.avatar-dot.ad2 { background: linear-gradient(135deg, #fb7185 0%, #f59e0b 100%); }
.avatar-dot.ad3 { background: linear-gradient(135deg, #34d399 0%, #22d3ee 100%); }
.avatar-dot.ad4 { background: linear-gradient(135deg, #c084fc 0%, #60a5fa 100%); }

.hero-right {
  width: 210rpx;
  height: 188rpx;
  position: relative;
  flex-shrink: 0;
}

.float-tag {
  position: absolute;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.92);
  border: 1rpx solid #e9d5ff;
  backdrop-filter: blur(8px);
  box-shadow: 0 12rpx 32rpx rgba(91, 33, 182, 0.1);
}

.ft-main {
  right: 0;
  top: 0;
  padding: 18rpx 16rpx;
  width: 190rpx;
  z-index: 1;
}

.ft-a {
  left: 0;
  top: 102rpx;
  padding: 10rpx 14rpx;
  opacity: 0.55;
  transform: scale(0.92);
  z-index: 3;
}

.ft-b {
  right: 8rpx;
  top: 10rpx;
  padding: 5rpx 10rpx;
  opacity: 0.45;
  transform: scale(0.82);
  z-index: 2;
}

.ft-code {
  display: block;
  font-size: 34rpx;
  font-weight: 900;
  color: #312e81;
}

.ft-sub {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #64748b;
}

.ft-mini {
  font-size: 22rpx;
  color: #6366f1;
  font-weight: 700;
}

.ft-b .ft-mini {
  font-size: 20rpx;
}

.hero-footer {
  position: relative;
  z-index: 1;
  margin-top: 22rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.hero-dots {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding-left: 4rpx;
}

.hero-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: #e2e8f0;
}

.hero-dot-on {
  width: 28rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, #a855f7 0%, #6366f1 100%);
}

.hero-cta {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: auto;
  box-sizing: border-box;
  border-radius: 999rpx;
  padding: 18rpx 32rpx;
  background: linear-gradient(90deg, #a855f7 0%, #6366f1 48%, #4f46e5 100%);
  box-shadow: 0 12rpx 32rpx rgba(99, 102, 241, 0.28);
}

.hero-cta-text {
  font-size: 26rpx;
  font-weight: 800;
  color: #ffffff;
}

.hero-cta-arrow {
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.95);
}

.section {
  margin-top: 22rpx;
}

.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.section-title {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.section-title-text {
  font-size: 28rpx;
  font-weight: 800;
  color: #111827;
}

.section-emoji {
  font-size: 28rpx;
  line-height: 1;
}

.section-more-text {
  font-size: 24rpx;
  color: #64748b;
}

.section-more-shuffle {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.shuffle-icon {
  font-size: 24rpx;
  color: #94a3b8;
  line-height: 1;
}

.hot-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  width: 100%;
  box-sizing: border-box;
}

.hot-card {
  width: 100%;
  min-width: 0;
  box-sizing: border-box;
  border-radius: 20rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  padding: 16rpx 12rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 10rpx 32rpx rgba(15, 23, 42, 0.06);
}

.hot-badge {
  display: inline-flex;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
}

.hot-badge-text {
  font-size: 18rpx;
  font-weight: 800;
  color: #334155;
}

.hot-title {
  margin-top: 10rpx;
  font-size: 22rpx;
  font-weight: 800;
  color: #111827;
  line-height: 1.35;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.hot-tag {
  font-size: 18rpx;
  color: #475569;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
  padding: 4rpx 8rpx;
  border-radius: 999rpx;
}

.hot-sub {
  display: block;
  margin-top: 8rpx;
  font-size: 18rpx;
  color: #64748b;
}

.hot-people {
  font-size: 18rpx;
  color: #94a3b8;
}

.hot-arrow {
  font-size: 28rpx;
  color: #cbd5e1;
}

.hot-card-hover {
  opacity: 0.96;
}

.hot-badge-top {
  background: #fff7ed;
  border-color: #fed7aa;
}

.hot-badge-new {
  background: #faf5ff;
  border-color: #e9d5ff;
}

.hot-tags {
  display: flex;
  gap: 6rpx;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.hot-foot {
  margin-top: 12rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hot-art {
  position: absolute;
  right: -28rpx;
  bottom: -28rpx;
  width: 120rpx;
  height: 120rpx;
  border-radius: 999rpx;
  opacity: 0.65;
  filter: blur(1px);
}

.hot-love .hot-art { background: radial-gradient(circle at 30% 30%, rgba(251, 113, 133, 0.70) 0%, rgba(168, 85, 247, 0) 70%); }
.hot-sbti .hot-art { background: radial-gradient(circle at 30% 30%, rgba(245, 158, 11, 0.72) 0%, rgba(167, 139, 250, 0.35) 70%); }
.hot-jung8 .hot-art { background: radial-gradient(circle at 30% 30%, rgba(34, 211, 238, 0.70) 0%, rgba(59, 130, 246, 0) 70%); }

.guess-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.guess-card {
  display: flex;
  gap: 16rpx;
  align-items: center;
  border-radius: 24rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  padding: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.guess-thumb {
  width: 128rpx;
  height: 104rpx;
  border-radius: 22rpx;
  background:
    radial-gradient(circle at 18% 16%, rgba(255, 255, 255, 0.78) 0%, rgba(255, 255, 255, 0) 34%),
    linear-gradient(135deg, #f8fafc 0%, #eef2ff 100%);
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  box-shadow:
    inset 0 0 0 1rpx rgba(255, 255, 255, 0.5),
    0 14rpx 28rpx rgba(99, 102, 241, 0.10);
  flex-shrink: 0;
  position: relative;
  overflow: hidden;
}

.guess-thumb::before,
.guess-thumb::after {
  content: "";
  position: absolute;
  border-radius: 999rpx;
  pointer-events: none;
}

.guess-thumb::before {
  right: -24rpx;
  top: -28rpx;
  width: 82rpx;
  height: 82rpx;
  background: rgba(255, 255, 255, 0.42);
}

.guess-thumb::after {
  left: 18rpx;
  bottom: 18rpx;
  width: 56rpx;
  height: 10rpx;
  background: rgba(255, 255, 255, 0.46);
  box-shadow: 28rpx -22rpx 0 rgba(255, 255, 255, 0.34);
}

.guess-thumb-glow {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  width: 44rpx;
  height: 44rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.36);
  box-shadow: 0 0 28rpx rgba(255, 255, 255, 0.48);
}

.guess-thumb-icon {
  position: absolute;
  left: 18rpx;
  top: 20rpx;
  font-size: 32rpx;
  line-height: 1;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.96);
  text-shadow: 0 4rpx 12rpx rgba(30, 41, 59, 0.18);
}

.guess-thumb-label {
  position: absolute;
  left: 18rpx;
  bottom: 16rpx;
  font-size: 18rpx;
  line-height: 1;
  color: rgba(255, 255, 255, 0.86);
  font-weight: 800;
}

.guess-pill {
  font-size: 20rpx;
  color: #475569;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
}

.guess-title {
  font-size: 26rpx;
  font-weight: 800;
  color: #111827;
}

.guess-desc {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: #64748b;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.guess-tag {
  font-size: 20rpx;
  color: #475569;
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
  background: #f1f5f9;
  border: 1rpx solid #e2e8f0;
}

.guess-meta {
  font-size: 20rpx;
  color: #94a3b8;
  padding: 6rpx 0;
}

.guess-cta {
  border-radius: 999rpx;
  padding: 14rpx 20rpx;
  background: #ffffff;
  border: 2rpx solid #7c3aed;
  box-shadow: none;
}

.guess-cta-meta {
  font-size: 20rpx;
  color: #94a3b8;
  text-align: right;
  max-width: 160rpx;
}

.guess-cta-text {
  font-size: 22rpx;
  font-weight: 800;
  color: #7c3aed;
}

.guess-empty {
  padding: 30rpx 18rpx;
  border-radius: 22rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
}

.guess-empty-text {
  font-size: 24rpx;
  color: #64748b;
}

.guess-card-hover {
  opacity: 0.96;
}

.guess-main {
  flex: 1;
  min-width: 0;
}

.guess-topline {
  display: flex;
  align-items: center;
  gap: 10rpx;
  flex-wrap: wrap;
}

.guess-new {
  font-size: 18rpx;
  font-weight: 800;
  color: #be185d;
  padding: 4rpx 10rpx;
  border-radius: 999rpx;
  background: #fce7f3;
  border: 1rpx solid #fbcfe8;
}

.guess-tags {
  margin-top: 10rpx;
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.guess-cta-col {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 8rpx;
  min-width: 132rpx;
}

.guess-mbti { background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #60a5fa 0%, #8b5cf6 100%); }
.guess-jung8 { background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #22d3ee 0%, #6366f1 100%); }
.guess-ace { background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #14b8a6 0%, #a78bfa 100%); }
.guess-love,
.guess-ideal,
.guess-likeLevel,
.guess-loveQuirk,
.guess-breakup,
.guess-coupleValues,
.guess-shady,
.guess-nen {
  background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #fb7185 0%, #c084fc 100%);
}
.guess-holland { background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #10b981 0%, #2563eb 100%); }
.guess-eq { background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #f59e0b 0%, #ec4899 100%); }
.guess-attachment,
.guess-avpd,
.guess-bpd,
.guess-ocpd,
.guess-ppd,
.guess-dpd,
.guess-depd,
.guess-hpd,
.guess-npd {
  background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #818cf8 0%, #f472b6 100%);
}
.guess-man,
.guess-sbti {
  background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #f59e0b 0%, #8b5cf6 100%);
}
.guess-animal,
.guess-plant {
  background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #34d399 0%, #38bdf8 100%);
}
.guess-sds { background: radial-gradient(circle at 78% 18%, rgba(255,255,255,0.58), transparent 30%), linear-gradient(135deg, #64748b 0%, #6366f1 100%); }

.load-state {
  margin-top: 22rpx;
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.sk1 { height: 120rpx; }
.sk2 { height: 90rpx; }
.sk3 { height: 90rpx; }

@keyframes pulse {
  0% { opacity: 0.65; }
  50% { opacity: 1; }
  100% { opacity: 0.65; }
}

.error-state {
  margin-top: 18rpx;
  padding: 22rpx 18rpx;
  border-radius: 18rpx;
  background: #ffe4e6;
  border: 1rpx solid #fecdd3;
}

.skeleton {
  height: 90rpx;
  border-radius: 18rpx;
  background: #e2e8f0;
  border: 1rpx solid #f1f5f9;
  animation: pulse 1.2s ease-in-out infinite;
}

.error-text {
  font-size: 24rpx;
  color: #9f1239;
}

.safe-bottom {
  height: 160rpx;
  padding-bottom: env(safe-area-inset-bottom);
  box-sizing: content-box;
}
