.wrap {
  padding: 48rpx 32rpx;
}

.hero {
  margin-bottom: 48rpx;
}

.title {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #222;
}

.sub {
  display: block;
  margin-top: 16rpx;
  font-size: 28rpx;
  color: #666;
}

.card {
  display: block;
  padding: 32rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.card.primary {
  background: #4298ff;
  color: #fff;
}

.card.card-sbti {
  background: #4d6a53;
  color: #fff;
}

.card.ghost {
  background: #fff;
  border: 1px solid #ddd;
  color: #333;
}

.card-title {
  display: block;
  font-size: 34rpx;
  font-weight: bold;
}

.card-desc {
  display: block;
  margin-top: 12rpx;
  font-size: 26rpx;
  opacity: 0.95;
}

.card.ghost .card-desc {
  color: #666;
}
