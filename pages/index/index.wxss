.home-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 10% 0%, rgba(255, 255, 255, 0.06) 0%, rgba(11, 18, 32, 0) 55%),
    radial-gradient(900rpx 900rpx at 90% 10%, rgba(255, 255, 255, 0.04) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.card-grid {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.test-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.35);
  backdrop-filter: blur(10px);
  position: relative;
  overflow: hidden;
}

.test-card::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0;
  width: 10rpx;
  height: 100%;
  background: rgba(255, 255, 255, 0.12);
}

.test-card::after {
  content: "";
  position: absolute;
  inset: 0;
  background: radial-gradient(900rpx 320rpx at 20% 0%, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0) 60%);
  pointer-events: none;
}

