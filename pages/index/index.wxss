.test-card-header {
  margin-bottom: 18rpx;
}

.test-card-title {
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  display: block;
}

.test-card-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.62);
  margin-top: 8rpx;
  display: block;
}

.tag-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 14rpx;
}

.tag {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.82);
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
}

.subcard-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.subcard {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 16rpx;
  padding: 22rpx;
}

.subcard-latest {
  border-style: dashed;
}

.subcard-hover {
  opacity: 0.96;
}

.subcard-main {
  min-width: 0;
}

.subcard-title {
  font-size: 30rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.90);
  display: block;
}

.subcard-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
  margin-top: 8rpx;
  display: block;
}

.subcard-meta {
  display: flex;
  align-items: center;
  gap: 14rpx;
  flex-shrink: 0;
}

.subcard-badge {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.88);
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  padding: 6rpx 12rpx;
  border-radius: 999rpx;
}

.subcard-time {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.58);
}

.subcard-arrow {
  font-size: 40rpx;
  color: rgba(255, 255, 255, 0.45);
  line-height: 1;
}
