.bpdr-page {
  min-height: 100vh;
  position: relative;
  background: #f4f6fb;
}

.bpdr-bg {
  position: fixed;
  inset: 0;
  background:
    radial-gradient(720rpx 320rpx at 10% 0%, rgba(251, 113, 133, 0.18) 0%, rgba(255, 255, 255, 0) 55%),
    radial-gradient(640rpx 300rpx at 100% 18%, rgba(167, 139, 250, 0.16) 0%, rgba(255, 255, 255, 0) 55%);
  pointer-events: none;
  z-index: 0;
}

.bpdr-inner {
  position: relative;
  z-index: 1;
  padding: 32rpx 28rpx 48rpx;
}

.bpdr-hero {
  text-align: center;
  padding: 16rpx 0 8rpx;
}

.bpdr-label {
  display: block;
  font-size: 22rpx;
  color: #64748b;
  font-weight: 600;
  line-height: 1.35;
}

.bpdr-tier {
  display: block;
  margin-top: 14rpx;
  font-size: 34rpx;
  font-weight: 900;
  color: #9f1239;
}

.bpdr-score {
  display: block;
  margin-top: 10rpx;
  font-size: 30rpx;
  font-weight: 800;
  color: #475569;
}

.bpdr-note {
  display: block;
  margin-top: 10rpx;
  font-size: 22rpx;
  color: #94a3b8;
}

.bpdr-card {
  margin-top: 28rpx;
  background: #ffffff;
  border-radius: 24rpx;
  border: 1rpx solid #e2e8f0;
  padding: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(15, 23, 42, 0.06);
}

.bpdr-desc {
  font-size: 28rpx;
  color: #475569;
  line-height: 1.55;
}

.bpdr-actions {
  margin-top: 32rpx;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.bpdr-btn {
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  padding: 22rpx 0;
  line-height: 1.2;
  text-align: center;
}

.bpdr-btn-text {
  font-size: 28rpx;
  font-weight: 700;
}

.bpdr-btn-primary {
  background: linear-gradient(90deg, #fb7185 0%, #c084fc 48%, #a855f7 100%);
}

.bpdr-btn-primary .bpdr-btn-text {
  color: #ffffff;
}

.bpdr-btn-ghost {
  background: #ffffff;
  border: 1rpx solid #fecdd3;
}

.bpdr-btn-ghost .bpdr-btn-text {
  color: #9f1239;
}
