.result-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 15% 0%, rgba(236, 72, 153, 0.24) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(900rpx 900rpx at 85% 10%, rgba(99, 102, 241, 0.22) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 26rpx;
  padding: 28rpx;
  box-shadow: 0 20rpx 70rpx rgba(0, 0, 0, 0.40);
  backdrop-filter: blur(10px);
}

.hero-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.hero-title {
  font-size: 44rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.95);
}

.hero-badge {
  font-size: 22rpx;
  color: rgba(96, 165, 250, 0.95);
  background: rgba(96, 165, 250, 0.14);
  border: 1rpx solid rgba(96, 165, 250, 0.22);
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
}

.hero-subtitle {
  font-size: 30rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.88);
  margin-top: 14rpx;
  display: block;
}

.hero-desc {
  margin-top: 10rpx;
}

.paragraph {
  font-size: 28rpx;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.86);
  margin-top: 16rpx;
  display: block;
}

.actions {
  display: flex;
  gap: 18rpx;
  margin-top: 22rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.action-primary {
  background: linear-gradient(90deg, #ec4899 0%, #6366f1 60%, #22c55e 120%);
  color: #ffffff;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

