.tarot-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 18% 12%, rgba(168, 85, 247, 0.22) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(900rpx 900rpx at 82% 0%, rgba(245, 158, 11, 0.14) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 22rpx;
}

.hero-image {
  width: 100%;
  height: 260rpx;
  border-radius: 18rpx;
  margin-bottom: 18rpx;
  background: rgba(255, 255, 255, 0.06);
}

.hero-header {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.hero-title {
  font-size: 38rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.94);
}

.hero-subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.74);
}

.hero-desc {
  margin-top: 18rpx;
}

.hero-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.60);
}

.question-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
  backdrop-filter: blur(8px);
}

.question-label {
  font-size: 26rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.90);
  margin-bottom: 12rpx;
  display: block;
}

.question-input {
  width: 100%;
  min-height: 160rpx;
  box-sizing: border-box;
  padding: 18rpx;
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  color: rgba(255, 255, 255, 0.92);
  font-size: 28rpx;
  line-height: 1.6;
}

.question-placeholder {
  color: rgba(255, 255, 255, 0.40);
}

.login-tip {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 18rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  background: rgba(255, 255, 255, 0.05);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
}

.login-tip-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.70);
}

.mini-btn {
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.90);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  font-size: 26rpx;
  font-weight: 700;
}

.mini-btn-cta {
  background: linear-gradient(90deg, rgba(245, 158, 11, 0.95) 0%, rgba(236, 72, 153, 0.95) 55%, rgba(168, 85, 247, 0.95) 120%);
  color: #0b1220;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}

.last-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
  backdrop-filter: blur(8px);
}

.last-row {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.last-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
}

.last-title {
  font-size: 28rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.90);
  text-align: right;
}

.actions {
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.action-btn {
  width: 100%;
  height: 92rpx;
  line-height: 92rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.action-primary {
  background: linear-gradient(90deg, rgba(168, 85, 247, 1) 0%, rgba(236, 72, 153, 1) 55%, rgba(245, 158, 11, 1) 120%);
  color: #ffffff;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.action-btn[disabled] {
  opacity: 0.55;
}
