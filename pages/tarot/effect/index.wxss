.effect-page {
  min-height: 100vh;
  background: radial-gradient(1100rpx 1100rpx at 18% 12%, rgba(168, 85, 247, 0.22) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(1100rpx 1100rpx at 82% 0%, rgba(236, 72, 153, 0.18) 0%, rgba(11, 18, 32, 0) 55%),
    radial-gradient(1000rpx 1000rpx at 60% 100%, rgba(245, 158, 11, 0.12) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.question-bar {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 22rpx;
  backdrop-filter: blur(8px);
}

.question-label {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.60);
  display: block;
  margin-bottom: 8rpx;
}

.question-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.90);
  line-height: 1.55;
  display: block;
}

.stage {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.scene {
  width: 520rpx;
  height: 640rpx;
  position: relative;
  margin: 10rpx 0 22rpx;
  perspective: 1200rpx;
}

.glow {
  position: absolute;
  top: -16%;
  right: -16%;
  bottom: -16%;
  left: -16%;
  border-radius: 999rpx;
  background: radial-gradient(circle at 40% 35%, rgba(245, 158, 11, 0.40) 0%, rgba(236, 72, 153, 0.22) 32%, rgba(168, 85, 247, 0.14) 60%, rgba(11, 18, 32, 0) 72%);
  opacity: 0;
  transition: opacity 600ms ease-in-out;
}

.glow-on {
  opacity: 1;
}

.halo {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 80rpx;
  height: 80rpx;
  border-radius: 999rpx;
  transform: translate(-50%, -50%) scale(0);
  opacity: 0;
  border: 2rpx solid rgba(245, 158, 11, 0.85);
  box-shadow: 0 0 0 10rpx rgba(245, 158, 11, 0.16);
  pointer-events: none;
}

.halo-on {
  animation: haloExpand 620ms cubic-bezier(0.06, 0.86, 0.2, 1) 1;
}

.particle {
  position: absolute;
  left: 50%;
  top: 50%;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(245, 158, 11, 0) 0%, rgba(245, 158, 11, 0.95) 45%, rgba(255, 255, 255, 0.75) 70%, rgba(255, 255, 255, 0) 100%);
  filter: blur(2px);
  pointer-events: none;
}

.card {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  border-radius: 30rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  box-shadow: 0 22rpx 80rpx rgba(0, 0, 0, 0.50);
  overflow: hidden;
  transform-style: preserve-3d;
  background: linear-gradient(180deg, rgba(59, 39, 74, 0.70) 0%, rgba(14, 21, 32, 0.85) 68%, rgba(14, 21, 32, 0.95) 100%);
}

.card-overlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  pointer-events: none;
  z-index: 1;
  background: radial-gradient(900rpx 900rpx at 30% 12%, rgba(245, 158, 11, 0.06) 0%, rgba(11, 18, 32, 0) 60%),
    linear-gradient(180deg, rgba(11, 18, 32, 0.04) 0%, rgba(11, 18, 32, 0.10) 100%);
}

.tap-hint {
  position: absolute;
  left: 50%;
  bottom: 36rpx;
  transform: translateX(-50%);
  z-index: 3;
  padding: 14rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.10);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  backdrop-filter: blur(8px);
  animation: hintPulse 1200ms ease-in-out infinite;
}

.tap-hint-text {
  font-size: 24rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
  white-space: nowrap;
}

.card-breath {
  animation: cardBreath 2400ms ease-in-out infinite;
}

.card-inner {
  width: 100%;
  height: 100%;
  position: relative;
  z-index: 2;
  transform-style: preserve-3d;
  transition: transform 800ms linear;
}

.card-flipped {
  transform: rotateY(180deg);
}

.card-side {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
  display: flex;
  flex-direction: column;
  align-items: stretch;
}

.card-back {
  position: relative;
  background: transparent;
}

.card-front {
  transform: rotateY(180deg);
  background: transparent;
}

.card-back-inner {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  box-sizing: border-box;
  padding: 0 26rpx;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.card-back-title {
  font-size: 38rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.94);
  text-align: center;
  width: 100%;
}

.card-back-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.60);
  text-align: center;
  width: 100%;
}

.card-front-inner {
  position: absolute;
  left: 50%;
  top: 50%;
  transform: translate(-50%, -50%);
  width: 100%;
  box-sizing: border-box;
  padding: 0 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
}

.card-front-title {
  font-size: 56rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.98);
}

.card-front-sub {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.70);
}

.card-front-kw {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
  text-align: center;
}

.result-card {
  width: 100%;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 22rpx;
  backdrop-filter: blur(8px);
  margin-bottom: 22rpx;
}

.result-head {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.result-head-title {
  font-size: 30rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.92);
}

.mini-btn {
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.86);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  font-size: 24rpx;
  font-weight: 600;
}

.mini-btn-cta {
  background: linear-gradient(90deg, rgba(245, 158, 11, 0.95) 0%, rgba(236, 72, 153, 0.95) 55%, rgba(168, 85, 247, 0.95) 120%);
  color: #0b1220;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  box-shadow: 0 16rpx 48rpx rgba(236, 72, 153, 0.18);
  animation: ctaPulse 1200ms cubic-bezier(0.12, 0.8, 0.2, 1) infinite;
}

@keyframes ctaPulse {
  0% { transform: scale(1); filter: brightness(1); }
  55% { transform: scale(1.04); filter: brightness(1.08); }
  100% { transform: scale(1); filter: brightness(1); }
}

.section {
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.10);
}

.section:first-of-type {
  border-top: none;
  padding-top: 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.90);
  display: block;
  margin-bottom: 10rpx;
}

.section-text {
  font-size: 28rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.88);
  display: block;
}

.actions {
  display: flex;
  gap: 18rpx;
  padding-bottom: calc(22rpx + env(safe-area-inset-bottom));
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0;
}

.action-primary {
  background: linear-gradient(90deg, rgba(168, 85, 247, 1) 0%, rgba(236, 72, 153, 1) 55%, rgba(245, 158, 11, 1) 120%);
  color: #ffffff;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

@keyframes cardBreath {
  0% { transform: scale(1); }
  50% { transform: scale(1.03); }
  100% { transform: scale(1); }
}

@keyframes haloExpand {
  0% { transform: translate(-50%, -50%) scale(0); opacity: 0; }
  18% { opacity: 1; }
  100% { transform: translate(-50%, -50%) scale(2); opacity: 0; }
}

@keyframes hintPulse {
  0% { transform: translateX(-50%) scale(1); opacity: 0.78; }
  55% { transform: translateX(-50%) scale(1.05); opacity: 1; }
  100% { transform: translateX(-50%) scale(1); opacity: 0.78; }
}
