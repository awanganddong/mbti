.result-page {
  min-height: 100vh;
  background: radial-gradient(900rpx 900rpx at 18% 12%, rgba(168, 85, 247, 0.18) 0%, rgba(11, 18, 32, 0) 60%),
    radial-gradient(900rpx 900rpx at 82% 0%, rgba(245, 158, 11, 0.12) 0%, rgba(11, 18, 32, 0) 55%),
    #0b1220;
}

.container {
  padding: 28rpx;
  box-sizing: border-box;
}

.hero-card {
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.12);
  border-radius: 24rpx;
  padding: 30rpx;
  box-shadow: 0 18rpx 60rpx rgba(0, 0, 0, 0.35);
  margin-bottom: 22rpx;
}

.hero-header {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.hero-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.hero-title {
  font-size: 34rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.92);
}

.hero-badge {
  font-size: 22rpx;
  padding: 10rpx 16rpx;
  border-radius: 999rpx;
  background: rgba(168, 85, 247, 0.18);
  border: 1rpx solid rgba(168, 85, 247, 0.35);
  color: rgba(255, 255, 255, 0.86);
  flex-shrink: 0;
}

.hero-subtitle {
  font-size: 42rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.96);
}

.hero-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
}

.hero-q {
  margin-top: 6rpx;
}

.hero-q-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.62);
}

.hero-q-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.90);
}

.hero-desc {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.section {
  padding: 16rpx 0;
  border-top: 1rpx solid rgba(255, 255, 255, 0.10);
}

.section:first-of-type {
  border-top: none;
  padding-top: 0;
}

.section-title {
  font-size: 26rpx;
  font-weight: 800;
  color: rgba(255, 255, 255, 0.92);
  display: block;
  margin-bottom: 10rpx;
}

.section-text {
  font-size: 28rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.90);
  display: block;
}

.paragraph {
  font-size: 28rpx;
  line-height: 1.65;
  color: rgba(255, 255, 255, 0.90);
}

.actions {
  display: flex;
  gap: 18rpx;
  padding-bottom: 18rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 18rpx;
  font-size: 30rpx;
  font-weight: 600;
  padding: 0;
}

.action-primary {
  background: linear-gradient(90deg, rgba(168, 85, 247, 1) 0%, rgba(236, 72, 153, 1) 55%, rgba(245, 158, 11, 1) 120%);
  color: #ffffff;
}

.action-secondary {
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.88);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
}

.ai-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.10);
  border-radius: 20rpx;
  padding: 22rpx;
  margin-bottom: 22rpx;
  backdrop-filter: blur(8px);
}

.ai-head {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 14rpx;
}

.ai-title {
  font-size: 30rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.92);
}

.ai-sub {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.52);
}

.ai-status {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  padding: 10rpx 0 2rpx;
}

.ai-status-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.64);
}

.ai-loading {
  display: flex;
  gap: 18rpx;
  align-items: center;
}

.ai-loading-card {
  width: 86rpx;
  height: 118rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, rgba(168, 85, 247, 0.55) 0%, rgba(236, 72, 153, 0.45) 55%, rgba(245, 158, 11, 0.45) 120%);
  border: 1rpx solid rgba(255, 255, 255, 0.16);
  position: relative;
  overflow: hidden;
  transform-origin: 50% 85%;
  animation: aiCardFloat 1.4s ease-in-out infinite;
}

.ai-loading-card::after {
  content: '';
  position: absolute;
  left: -60%;
  top: -10%;
  width: 60%;
  height: 140%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.26) 45%, rgba(255, 255, 255, 0) 100%);
  transform: rotate(12deg);
  animation: aiShimmer 1.2s ease-in-out infinite;
}

.ai-loading-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.ai-loading-line {
  height: 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.10);
  position: relative;
  overflow: hidden;
}

.ai-loading-line.short {
  width: 72%;
}

.ai-loading-line::after {
  content: '';
  position: absolute;
  left: -40%;
  top: 0;
  width: 40%;
  height: 100%;
  background: linear-gradient(90deg, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0.20) 50%, rgba(255, 255, 255, 0) 100%);
  animation: aiShimmer 1.1s ease-in-out infinite;
}

@keyframes aiCardFloat {
  0% {
    transform: translateY(0) rotate(-2deg) scale(1);
    opacity: 0.92;
  }
  50% {
    transform: translateY(-8rpx) rotate(2deg) scale(1.02);
    opacity: 1;
  }
  100% {
    transform: translateY(0) rotate(-2deg) scale(1);
    opacity: 0.92;
  }
}

@keyframes aiShimmer {
  0% {
    transform: translateX(0) rotate(12deg);
    opacity: 0.0;
  }
  25% {
    opacity: 0.9;
  }
  100% {
    transform: translateX(260%) rotate(12deg);
    opacity: 0.0;
  }
}

.mini-btn {
  height: 70rpx;
  line-height: 70rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.08);
  color: rgba(255, 255, 255, 0.90);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  font-size: 26rpx;
  font-weight: 700;
}

.mini-btn-cta {
  background: linear-gradient(90deg, rgba(245, 158, 11, 0.95) 0%, rgba(236, 72, 153, 0.95) 55%, rgba(168, 85, 247, 0.95) 120%);
  color: #0b1220;
  border: 1rpx solid rgba(255, 255, 255, 0.12);
}
