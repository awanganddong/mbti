page {
  background: #f5f5f5;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  text-align: center;
  margin: 32rpx 0 24rpx;
}

.paragraph {
  text-align: justify;
  line-height: 1.65;
  margin-bottom: 16rpx;
}

.list-item {
  text-align: justify;
  line-height: 1.65;
  margin-bottom: 12rpx;
  padding-left: 12rpx;
}
