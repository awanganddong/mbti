/* 全局样式 */
page {
  font-family: 'PingFang SC', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  background-color: #f5f5f5;
  color: #333;
}

.container {
  padding: 20rpx;
  box-sizing: border-box;
}

.btn {
  display: block;
  width: 100%;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  border-radius: 40rpx;
  font-size: 32rpx;
  margin: 20rpx 0;
}

.btn-primary {
  background-color: #1890ff;
  color: white;
}

.btn-default {
  background-color: white;
  color: #333;
  border: 1rpx solid #ddd;
}

.question {
  font-size: 32rpx;
  margin: 40rpx 0;
  line-height: 1.5;
}

.option {
  display: flex;
  align-items: center;
  padding: 30rpx;
  background-color: white;
  border-radius: 20rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.option-radio {
  width: 40rpx;
  height: 40rpx;
  margin-right: 20rpx;
}

.progress-bar {
  width: 100%;
  height: 10rpx;
  background-color: #eee;
  border-radius: 5rpx;
  margin: 40rpx 0;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background-color: #1890ff;
  transition: width 0.3s;
}

.result-card {
  background-color: white;
  border-radius: 20rpx;
  padding: 40rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.result-title {
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
  text-align: center;
}

.result-desc {
  font-size: 28rpx;
  line-height: 1.5;
  margin-bottom: 20rpx;
}

.history-item {
  background-color: white;
  border-radius: 20rpx;
  padding: 30rpx;
  margin: 20rpx 0;
  box-shadow: 0 2rpx 10rpx rgba(0, 0, 0, 0.05);
}

.history-date {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.history-result {
  font-size: 28rpx;
  font-weight: bold;
}