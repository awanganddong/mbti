/* 全局：结果页「分享给好友」原生按钮样式（与各页 ghost 按钮视觉接近） */
button.result-share-native {
  display: block;
  width: 100%;
  margin: 0 0 16rpx 0;
  padding: 22rpx 0;
  box-sizing: border-box;
  border-radius: 999rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
  text-align: center;
  background: #ffffff;
  color: #475569;
  border: 1rpx solid #e2e8f0;
}

button.result-share-native::after {
  border: none;
}
